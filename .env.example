# Kubernetes MCP Server - Environment Configuration
# Copy this file to .env and fill in the values

# ─── Cluster Registry ───────────────────────────────────────────
# Define clusters as JSON array. Each entry needs:
#   name, flavor, and one of:
#     - proxy_url (for kubectl proxy / API gateway mode – no token needed)
#     - api_server + sa_token (or token_path) + ca_cert (or ca_path)
#
# Example using kubectl proxy (run: kubectl proxy --port=8001):
# CLUSTER_REGISTRY='[
#   {
#     "name": "local",
#     "flavor": "vanilla",
#     "proxy_url": "http://localhost:8001"
#   }
# ]'
#
# Example using direct API server access:
# CLUSTER_REGISTRY='[
#   {
#     "name": "prod-gke",
#     "flavor": "gke",
#     "api_server": "https://35.x.x.x",
#     "sa_token": "eyJhbGciOi...",
#     "ca_cert_path": "/path/to/ca.crt",
#     "namespace": "default"
#   }
# ]'

CLUSTER_REGISTRY='[]'

# ─── MCP Server Settings ────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080
MCP_TRANSPORT=streamable-http
MCP_LOG_LEVEL=info

# ─── Feature Flags ──────────────────────────────────────────────
ENABLE_SELF_HEAL=true
ENABLE_RCA=true
READ_ONLY=false
